// Physical Constraints — Tang Nano 20K
// MG90S servo: S1 (pin 87) = +90°, S2 (pin 88) = –90°, servo PWM = pin 71

IO_LOC  "clk"       4;
IO_PORT "clk"       IO_TYPE=LVCMOS33;

IO_LOC  "servo_pwm" 71;
IO_PORT "servo_pwm" IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "btn_s1"    87;
IO_PORT "btn_s1"    IO_TYPE=LVCMOS33 PULL_MODE=UP;

IO_LOC  "btn_s2"    88;
IO_PORT "btn_s2"    IO_TYPE=LVCMOS33 PULL_MODE=UP;
