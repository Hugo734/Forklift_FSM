// Physical Constraints — Tang Nano 20K

IO_LOC  "clk"       4;
IO_PORT "clk"       IO_TYPE=LVCMOS33;

IO_LOC  "servo_pwm" 71;
IO_PORT "servo_pwm" IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "btn_cw"    88;
IO_PORT "btn_cw"    IO_TYPE=LVCMOS33 PULL_MODE=UP;

IO_LOC  "btn_ccw"   87;
IO_PORT "btn_ccw"   IO_TYPE=LVCMOS33 PULL_MODE=UP;
